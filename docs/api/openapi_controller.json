{
  "openapi": "3.1.0",
  "info": {
    "title": "MIC Traffic Controller",
    "description": "Central configuration & orchestration API for the **Multi-Protocol Traffic Generation and Analysis** system (HSRW \u00b7 Mobile & Internet Computing \u00b7 SS2026).\n\nCoordinates the HTTP/2, QUIC, MQTT and TCP/UDP generators, loads multi-phase YAML traffic profiles, exposes live metrics, and runs an autonomous Adaptive Control loop that re-tunes generator rates based on observed error rates.",
    "contact": {
      "name": "MIC Final Project \u00b7 SS2026",
      "url": "https://www.hochschule-rhein-waal.de/"
    },
    "version": "1.0.0"
  },
  "paths": {
    "/start": {
      "post": {
        "tags": [
          "Control"
        ],
        "summary": "Start traffic generation",
        "description": "Loads the given YAML profile, applies phase 1 to every generator, starts them, and launches the background phase runner (and Adaptive Control, if the phase defines it).",
        "operationId": "start_start_post",
        "parameters": [
          {
            "name": "profile",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Name of the YAML profile in config/ to run",
              "default": "balanced",
              "title": "Profile"
            },
            "description": "Name of the YAML profile in config/ to run"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StartStopResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/stop": {
      "post": {
        "tags": [
          "Control"
        ],
        "summary": "Stop traffic generation",
        "description": "Stops the phase runner, disables Adaptive Control, and tells every generator to stop sending traffic.",
        "operationId": "stop_stop_post",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          }
        }
      }
    },
    "/config/load": {
      "post": {
        "tags": [
          "Configuration"
        ],
        "summary": "Load a YAML traffic profile",
        "description": "Sets the active profile. If the system is currently running, phase 1 of the new profile is applied to all generators immediately.",
        "operationId": "load_config_config_load_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConfigLoadRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StartStopResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/generator/{name}": {
      "patch": {
        "tags": [
          "Configuration"
        ],
        "summary": "Patch a single generator's configuration",
        "description": "Forwards arbitrary key/value overrides to one generator's `/config` endpoint, e.g. `{\"rate\": 80}`. Useful for live demo tweaks during the presentation.",
        "operationId": "patch_generator_generator__name__patch",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Name"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GeneratorPatch",
                "description": "Fields to override, forwarded as-is"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/generator/{name}/start": {
      "post": {
        "tags": [
          "Configuration"
        ],
        "summary": "Start a single generator",
        "description": "Forwards to the generator's own `/start` endpoint. Used by the dashboard's per-protocol on/off switches; does not affect the others.",
        "operationId": "start_generator_generator__name__start_post",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Name"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/generator/{name}/stop": {
      "post": {
        "tags": [
          "Configuration"
        ],
        "summary": "Stop a single generator",
        "description": "Forwards to the generator's own `/stop` endpoint. Used by the dashboard's per-protocol on/off switches; does not affect the others.",
        "operationId": "stop_generator_generator__name__stop_post",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Name"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/status": {
      "get": {
        "tags": [
          "Monitoring"
        ],
        "summary": "Get full system status",
        "description": "Returns whether the system is running, the active profile/phase, Adaptive Control state, live per-generator status, aggregated metrics, and the most recent log entries.",
        "operationId": "status_status_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            }
          }
        }
      }
    },
    "/profiles": {
      "get": {
        "tags": [
          "Configuration"
        ],
        "summary": "List available YAML profiles",
        "operationId": "list_profiles_profiles_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfilesResponse"
                }
              }
            }
          }
        }
      }
    },
    "/log": {
      "get": {
        "tags": [
          "Monitoring"
        ],
        "summary": "Get the full configuration / adaptive-control log",
        "operationId": "get_log_log_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LogResponse"
                }
              }
            }
          }
        }
      }
    },
    "/adaptive/status": {
      "get": {
        "tags": [
          "Adaptive Control"
        ],
        "summary": "Get the current Adaptive Control state",
        "description": "Shows whether Adaptive Control is active and, per generator, the most recent autonomous scaling decision (error rate observed, action taken, and the rate value(s) that were applied).",
        "operationId": "adaptive_status_adaptive_status_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AdaptiveStatusResponse"
                }
              }
            }
          }
        }
      }
    },
    "/adaptive/toggle": {
      "post": {
        "tags": [
          "Adaptive Control"
        ],
        "summary": "Manually enable or disable Adaptive Control",
        "description": "Lets you switch Adaptive Control on or off independently of the active profile's phase definitions; handy for demonstrating the feature live. When enabled without a phase-specific config, demo-tuned defaults are used (check every 5s, scale up at <=0% errors and <=50ms latency, scale down at >=5% errors or >=150ms latency, x1.2 up / x0.5 down), fast and dramatic enough to react visibly to the dashboard's Fault Injection sliders (fault_rate / extra_latency_ms) within 5-10 seconds.",
        "operationId": "adaptive_toggle_adaptive_toggle_post",
        "parameters": [
          {
            "name": "enabled",
            "in": "query",
            "required": true,
            "schema": {
              "type": "boolean",
              "description": "true to enable, false to disable",
              "title": "Enabled"
            },
            "description": "true to enable, false to disable"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AdaptiveToggleResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "Monitoring"
        ],
        "summary": "Liveness check",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AdaptiveDecision": {
        "properties": {
          "multiplier": {
            "type": "number",
            "title": "Multiplier",
            "description": "Current scaling factor applied to the profile's base rate(s)"
          },
          "error_rate": {
            "type": "number",
            "title": "Error Rate",
            "description": "Error rate observed in the last check interval"
          },
          "action": {
            "type": "string",
            "title": "Action",
            "description": "'up', 'down', or 'hold'"
          },
          "applied": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Applied",
            "description": "Rate values that were sent to the generator"
          },
          "checked_at": {
            "type": "string",
            "title": "Checked At"
          }
        },
        "type": "object",
        "required": [
          "multiplier",
          "error_rate",
          "action",
          "applied",
          "checked_at"
        ],
        "title": "AdaptiveDecision"
      },
      "AdaptiveStatusResponse": {
        "properties": {
          "enabled": {
            "type": "boolean",
            "title": "Enabled"
          },
          "generators": {
            "additionalProperties": {
              "$ref": "#/components/schemas/AdaptiveDecision"
            },
            "type": "object",
            "title": "Generators"
          }
        },
        "type": "object",
        "required": [
          "enabled",
          "generators"
        ],
        "title": "AdaptiveStatusResponse"
      },
      "AdaptiveToggleResponse": {
        "properties": {
          "ok": {
            "type": "boolean",
            "title": "Ok",
            "default": true
          },
          "enabled": {
            "type": "boolean",
            "title": "Enabled"
          }
        },
        "type": "object",
        "required": [
          "enabled"
        ],
        "title": "AdaptiveToggleResponse"
      },
      "ConfigLoadRequest": {
        "properties": {
          "profile": {
            "type": "string",
            "title": "Profile",
            "description": "Name of a YAML file in config/ (without extension)",
            "examples": [
              "mqtt_heavy"
            ]
          }
        },
        "type": "object",
        "required": [
          "profile"
        ],
        "title": "ConfigLoadRequest"
      },
      "GeneratorPatch": {
        "properties": {},
        "additionalProperties": true,
        "type": "object",
        "title": "GeneratorPatch",
        "description": "Arbitrary key/value overrides forwarded verbatim to the target generator's `/config` endpoint.",
        "example": {
          "payload_size": 4096,
          "rate": 80
        }
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "ok": {
            "type": "boolean",
            "title": "Ok",
            "default": true
          }
        },
        "type": "object",
        "title": "HealthResponse"
      },
      "LogEntry": {
        "properties": {
          "time": {
            "type": "string",
            "title": "Time",
            "description": "HH:MM:SS timestamp"
          },
          "level": {
            "type": "string",
            "title": "Level",
            "description": "info | success | adaptive"
          },
          "message": {
            "type": "string",
            "title": "Message"
          }
        },
        "type": "object",
        "required": [
          "time",
          "level",
          "message"
        ],
        "title": "LogEntry"
      },
      "LogResponse": {
        "properties": {
          "log": {
            "items": {
              "$ref": "#/components/schemas/LogEntry"
            },
            "type": "array",
            "title": "Log"
          }
        },
        "type": "object",
        "required": [
          "log"
        ],
        "title": "LogResponse"
      },
      "OkResponse": {
        "properties": {
          "ok": {
            "type": "boolean",
            "title": "Ok",
            "default": true
          },
          "note": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Note",
            "description": "Optional human-readable detail."
          }
        },
        "type": "object",
        "title": "OkResponse"
      },
      "ProfilesResponse": {
        "properties": {
          "profiles": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Profiles",
            "description": "Names of available YAML profiles in config/"
          }
        },
        "type": "object",
        "required": [
          "profiles"
        ],
        "title": "ProfilesResponse"
      },
      "RampStatus": {
        "properties": {
          "phase": {
            "type": "string",
            "title": "Phase",
            "description": "'warmup' or 'cooldown'"
          },
          "progress": {
            "type": "number",
            "title": "Progress",
            "description": "Ramp progress, 0.0 (just started) to 1.0 (complete)"
          }
        },
        "type": "object",
        "required": [
          "phase",
          "progress"
        ],
        "title": "RampStatus"
      },
      "StartStopResponse": {
        "properties": {
          "ok": {
            "type": "boolean",
            "title": "Ok",
            "default": true
          },
          "profile": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Profile",
            "description": "Profile that was (re)started, if any."
          },
          "note": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Note"
          }
        },
        "type": "object",
        "title": "StartStopResponse"
      },
      "StatusResponse": {
        "properties": {
          "running": {
            "type": "boolean",
            "title": "Running"
          },
          "active_profile": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Active Profile"
          },
          "active_phase": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Active Phase"
          },
          "adaptive_enabled": {
            "type": "boolean",
            "title": "Adaptive Enabled"
          },
          "adaptive_status": {
            "additionalProperties": true,
            "type": "object",
            "title": "Adaptive Status",
            "description": "Most recent Adaptive Control decision per generator"
          },
          "ramp_status": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/RampStatus"
              },
              {
                "type": "null"
              }
            ],
            "description": "Active warmup/cooldown ramp, if any"
          },
          "generators": {
            "additionalProperties": true,
            "type": "object",
            "title": "Generators",
            "description": "Live /status response of each generator"
          },
          "metrics": {
            "additionalProperties": true,
            "type": "object",
            "title": "Metrics",
            "description": "Aggregated /metrics response of the Metrics Collector"
          },
          "log": {
            "items": {
              "$ref": "#/components/schemas/LogEntry"
            },
            "type": "array",
            "title": "Log"
          }
        },
        "type": "object",
        "required": [
          "running",
          "active_profile",
          "active_phase",
          "adaptive_enabled",
          "generators",
          "metrics",
          "log"
        ],
        "title": "StatusResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  },
  "tags": [
    {
      "name": "Control",
      "description": "Start or stop the entire traffic-generation system (all generators, all phases)."
    },
    {
      "name": "Configuration",
      "description": "Load YAML traffic profiles and patch individual generators at runtime."
    },
    {
      "name": "Monitoring",
      "description": "Inspect live status, aggregated metrics and the timestamped configuration-change log."
    },
    {
      "name": "Adaptive Control",
      "description": "Autonomous, closed-loop traffic shaping: the controller periodically reads each generator's error rate (and latency, where reported) and automatically scales its rate up or down according to the thresholds defined in the active YAML profile's `adaptive_control` block; no human interaction required."
    }
  ]
}